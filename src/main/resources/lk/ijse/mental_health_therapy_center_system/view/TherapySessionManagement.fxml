<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1200" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.mental_health_therapy_center_system.controller.TherapySessionController">

    <!-- TOP NAV -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" style="-fx-background-color: #111111; -fx-border-color: #5D0E41; -fx-border-width: 0 0 2 0;">
            <padding><Insets left="30" right="30" /></padding>
            <Label style="-fx-font-family: 'Georgia'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FF204E;" text="SERENITY" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #777;" text="  |  Therapy Session Scheduling" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onMouseClicked="#navigateDashboard" style="-fx-background-color: transparent; -fx-border-color: #5D0E41; -fx-border-width: 1; -fx-border-radius: 3; -fx-text-fill: #777; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 6 18;" text="← Dashboard" />
        </HBox>
    </top>

    <center>
        <HBox spacing="0">

               <!-- LEFT: Form Panel -->
            <ScrollPane fitToWidth="true" prefWidth="390" style="-fx-background: #0d0d0d; -fx-background-color: #0d0d0d; -fx-border-color: #1a1a1a; -fx-border-width: 0 1 0 0;">
                <VBox spacing="16">
                    <padding>
                  <Insets bottom="30" left="28" right="28" top="30" />
               </padding>

                       <Label style="-fx-font-size: 10px; -fx-text-fill: #FF204E; -fx-letter-spacing: 3px; -fx-font-weight: bold;" text="SESSION DETAILS" />
                    <Separator style="-fx-background-color: #222;" />

                       <!-- Session ID -->
                    <VBox spacing="5">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #555; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="SESSION ID" />
                        <TextField fx:id="therapySessionId" editable="false" prefHeight="40" promptText="Auto-generated" style="-fx-background-color: #0a0a0a; -fx-border-color: #222; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #555; -fx-font-size: 13px; -fx-prompt-text-fill: #333;" />
                    </VBox>

                       <!-- Patient -->
                    <VBox spacing="5">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A0153E; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="PATIENT *">
                     <padding>
                        <Insets top="5.0" />
                     </padding>
                  </Label>
                        <ComboBox fx:id="PatientsComboBox" prefHeight="40" prefWidth="334" promptText="Select patient" style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #444;" stylesheets="@styles/comboBox.css" />
                    </VBox>

                       <!-- Therapist -->
                    <VBox spacing="5" />

                       <!-- Therapy Program -->
                    <VBox spacing="5">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A0153E; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="THERAPY PROGRAM *">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </Label>
                        <ComboBox fx:id="ProgramsComboBox" onMouseClicked="#loadTherapyPrograms" prefHeight="40" prefWidth="334" promptText="Select therapy program" style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #444;" stylesheets="@styles/comboBox.css">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </ComboBox>
                    </VBox>

                       <!-- Session Date -->
                    <VBox spacing="5">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A0153E; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="SESSION DATE *">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                     <padding>
                        <Insets top="10.0" />
                     </padding>
                  </Label>
                        <DatePicker fx:id="sessionDatePicker" prefHeight="40" prefWidth="334" promptText="Select session date" style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 13px;">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </DatePicker>
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A0153E; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="TIME PERIOD *">
                     <padding>
                        <Insets top="10.0" />
                     </padding>
                  </Label>
                        <ComboBox fx:id="TimesComboBox" prefHeight="40" prefWidth="334" promptText="e.g. 13:00 – 14:00" style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #444;" stylesheets="@styles/comboBox.css" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A0153E; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="THERAPIST *">
                     <padding>
                        <Insets top="12.0" />
                     </padding>
                  </Label>
                        <ComboBox fx:id="TherapistsComboBox" onMouseClicked="#loadTherapists" prefHeight="40" prefWidth="334" promptText="Select available therapist" style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #444;" stylesheets="@styles/comboBox.css" />
                    </VBox>

                       <!-- Time Period -->
                    <VBox spacing="5" />

                       <!-- Status -->
                    <VBox spacing="5" />

                       <!-- Action Buttons -->
                    <VBox spacing="10">
                        <padding>
                     <Insets top="10" />
                  </padding>
                        <HBox spacing="10">
                            <Button onAction="#bookSession" prefHeight="40" prefWidth="155" style="-fx-background-color: linear-gradient(to right, #A0153E, #FF204E); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" text="Book Session" />
                            <Button onAction="#updateSession" prefHeight="40" prefWidth="105" style="-fx-background-color: #1a1a1a; -fx-border-color: #A0153E; -fx-border-width: 1; -fx-border-radius: 4; -fx-text-fill: #A0153E; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="Update" />
                        </HBox>
                        <HBox spacing="10">
                            <Button onAction="#cancelSession" prefHeight="38" prefWidth="155" style="-fx-background-color: #1a1a1a; -fx-border-color: #5D0E41; -fx-border-width: 1; -fx-border-radius: 4; -fx-text-fill: #FF204E; -fx-font-size: 12px; -fx-cursor: hand;" text="Cancel Session" />
                            <Button onAction="#resetFields" prefHeight="38" prefWidth="105" style="-fx-background-color: transparent; -fx-border-color: #333; -fx-border-width: 1; -fx-border-radius: 4; -fx-text-fill: #666; -fx-font-size: 12px; -fx-cursor: hand;" text="Reset" />
                        </HBox>
                    </VBox>

                   </VBox>
            </ScrollPane>

            <!-- RIGHT: Table Panel -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="28" left="28" right="28" top="30" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label style="-fx-font-family: 'Georgia'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="SESSION RECORDS" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField prefHeight="38" prefWidth="260" promptText="🔍  Search by patient or therapist..." style="-fx-background-color: #1a1a1a; -fx-border-color: #5D0E41; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #555;" />
                    <Button onAction="#searchTherapySession" prefHeight="38" style="-fx-background-color: #A0153E; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 0 18;" text="Search" />
                </HBox>

                <Separator style="-fx-background-color: #1e1e1e;" />

                <TableView fx:id="therapySessionTable" layoutX="10.0" layoutY="10.0" onMouseClicked="#handleTableRowClick" onSort="#loadTherapists" prefHeight="332.0" prefWidth="959.0">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="46.39999008178711" text="Id" />
                        <TableColumn fx:id="colPatient" prefWidth="85.0" text="Patient Id" />
                        <TableColumn fx:id="colProgram" prefWidth="85.0" text="Program Id" />
                        <TableColumn fx:id="colTherapist" prefWidth="85.0" text="Therapist Id" />
                        <TableColumn fx:id="colTimePeriod" prefWidth="251.53302001953125" text="Time Period " />
                        <TableColumn fx:id="colDate" prefWidth="201.67486572265625" text="Date" />
                        <TableColumn fx:id="colStatus" prefWidth="116.8250732421875" text="Status" />
                    </columns>
                    <stylesheets>
                        <URL value="@styles/table.css" />
                    </stylesheets>
                </TableView>
            </VBox>

        </HBox>
    </center>

</BorderPane>
