<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1200" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.mental_health_therapy_center_system.controller.TherapyProgramController">

    <!-- TOP NAV -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" style="-fx-background-color: #111111; -fx-border-color: #5D0E41; -fx-border-width: 0 0 2 0;">
            <padding><Insets left="30" right="30" /></padding>
            <Label style="-fx-font-family: 'Georgia'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FF204E;" text="SERENITY" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #777;" text="  |  Therapy Program Management" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-font-size: 10px; -fx-text-fill: #FF204E; -fx-background-color: #1a0008; -fx-border-color: #FF204E; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 10; -fx-font-weight: bold;" text="ADMIN ONLY">
                <HBox.margin><Insets right="16" /></HBox.margin>
            </Label>
            <Button fx:id="goToDashboardBtn" style="-fx-background-color: transparent; -fx-border-color: #5D0E41; -fx-border-width: 1; -fx-border-radius: 3; -fx-text-fill: #777; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 6 18;" text="← Dashboard" />
        </HBox>
    </top>

    <center>
        <HBox spacing="0">

            <!-- LEFT: Form Panel -->
            <ScrollPane fitToWidth="true" prefWidth="380" style="-fx-background: #0d0d0d; -fx-background-color: #0d0d0d; -fx-border-color: #1a1a1a; -fx-border-width: 0 1 0 0;">
                <VBox spacing="16">
                    <padding><Insets bottom="30" left="28" right="28" top="30" /></padding>

                    <Label style="-fx-font-size: 10px; -fx-text-fill: #FF204E; -fx-letter-spacing: 3px; -fx-font-weight: bold;" text="PROGRAM DETAILS" />
                    <Separator style="-fx-background-color: #222;" />

                    <!-- ID -->
                    <VBox spacing="5">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #555; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="PROGRAM ID" />
                        <TextField fx:id="therapyId" editable="false" prefHeight="40" promptText="Auto-generated" style="-fx-background-color: #0a0a0a; -fx-border-color: #222; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #555; -fx-font-size: 13px; -fx-prompt-text-fill: #333;" />
                    </VBox>

                    <!-- Program Name -->
                    <VBox spacing="5">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A0153E; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="PROGRAM NAME *" />
                        <TextField fx:id="therapyName" prefHeight="40" promptText="e.g. Cognitive Behavioural Therapy" style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #444;" />
                    </VBox>

                    <!-- Duration -->
                    <VBox spacing="5">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A0153E; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="DURATION *" />
                        <TextField fx:id="therapyDuration" prefHeight="40" promptText="e.g. 8 Weeks / 3 Months" style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #444;" />
                    </VBox>

                    <!-- Fee -->
                    <VBox spacing="5">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A0153E; -fx-letter-spacing: 2px; -fx-font-weight: bold;" text="FEE (LKR) *" />
                        <TextField fx:id="therapyFee" prefHeight="40" promptText="e.g. 15000.00" style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #444;" />
                    </VBox>

                    <!-- Description -->
                    <VBox spacing="5" />

                    <!-- Link Therapist -->
                    <VBox spacing="5" />

                    <!-- Action Buttons -->
                    <VBox spacing="10">
                        <padding><Insets top="10" /></padding>
                        <HBox spacing="10">
                            <Button fx:id="therapySaveBtn" onAction="#saveTherapyProgram" prefHeight="40" prefWidth="155" style="-fx-background-color: linear-gradient(to right, #A0153E, #FF204E); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" text="Add Program" />
                            <Button fx:id="therapyUpdateBtn" onAction="#updateTherapyProgram" prefHeight="40" prefWidth="105" style="-fx-background-color: #1a1a1a; -fx-border-color: #A0153E; -fx-border-width: 1; -fx-border-radius: 4; -fx-text-fill: #A0153E; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="Update" />
                        </HBox>
                        <HBox spacing="10">
                            <Button fx:id="therapyDeleteBtn" onAction="#deleteTherapyProgram" prefHeight="38" prefWidth="155" style="-fx-background-color: #1a1a1a; -fx-border-color: #5D0E41; -fx-border-width: 1; -fx-border-radius: 4; -fx-text-fill: #FF204E; -fx-font-size: 12px; -fx-cursor: hand;" text="Delete" />
                            <Button fx:id="therapyResetBtn" onAction="#resetAllFields" prefHeight="38" prefWidth="105" style="-fx-background-color: transparent; -fx-border-color: #333; -fx-border-width: 1; -fx-border-radius: 4; -fx-text-fill: #666; -fx-font-size: 12px; -fx-cursor: hand;" text="Reset" />
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- RIGHT: Table Panel -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="28" left="28" right="28" top="30" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label style="-fx-font-family: 'Georgia'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="THERAPY PROGRAMS" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="therapyProgramSearch" prefHeight="38" prefWidth="290" promptText="🔍  Search by program name..." style="-fx-background-color: #1a1a1a; -fx-border-color: #5D0E41; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-font-size: 13px; -fx-prompt-text-fill: #555;" />
                    <Button fx:id="therapyProgramSearchBtn" prefHeight="38" style="-fx-background-color: #A0153E; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 0 18;" text="Search" />
                </HBox>

                <Separator style="-fx-background-color: #1e1e1e;" />

                <TableView fx:id="therapyProgramTable" layoutX="10.0" layoutY="10.0" onMouseClicked="#handleTableClick" prefHeight="332.0" prefWidth="959.0">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="46.39999008178711" text="Id" />
                        <TableColumn fx:id="colName" prefWidth="335.4429931640625" text="Program Name" />
                        <TableColumn fx:id="colDuration" prefWidth="204.0" text="Duration" />
                        <TableColumn fx:id="colFee" prefWidth="164.709228515625" text="Fee" />
                        <TableColumn fx:id="colStatus" prefWidth="110.474365234375" text="Status" />
                    </columns>
               <stylesheets>
                  <URL value="@styles/table.css" />
               </stylesheets>
                </TableView>
            </VBox>
        </HBox>
    </center>

</BorderPane>
